// This devcontainer is not meant to be opened directly in VS Code.
// It exists solely so that `.github/workflows/publish-full-image.yml` can build
// and publish a pre-baked image (Dockerfile + the sshd Feature below) to:
//   ghcr.io/bugrasan/devcontainer-base-ai/full:latest
// which the root ../../devcontainer.json then consumes via its "image" property.
{
	"name": "devcontainer-base-ai full image",

	"build": {
		"dockerfile": "Dockerfile"
	},

	// https://github.com/devcontainers/features/tree/main/src/sshd
	// Not setting SSHD_PORT/START_SSHD here: the Feature's install.sh already
	// defaults SSHD_PORT to 2222, and it bakes its own 'entrypoint'
	// (ssh-init.sh, which runs '/etc/init.d/ssh start' unconditionally on every
	// container start) into the image metadata, so START_SSHD's build-time-only
	// eager start has no lasting effect either way. If a non-default port is ever
	// needed, set SSHD_PORT here (it must be set at build time - the Feature's
	// install.sh bakes it into /etc/ssh/sshd_config once, when this image is
	// built, and never reads it again) and update root's 'forwardPorts'/
	// 'portsAttributes' to match.
	"features": {
		"ghcr.io/devcontainers/features/sshd:1": {}
	}
}
