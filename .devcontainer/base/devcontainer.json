// This devcontainer is not meant to be opened directly in VS Code.
// It exists solely so that `.github/workflows/publish-base-image.yml` can build
// and publish a pre-baked image (Dockerfile.trixie + these Features) to:
//   ghcr.io/bugrasan/devcontainer-base-ai/base:latest
// which the root ../devcontainer.json then consumes via its "image" property.
{
	"name": "devcontainer-base-ai base image",

	// Same Dockerfile used by the root ../devcontainer.json's commented-out "build" alternative.
	"build": {
		"dockerfile": "Dockerfile.mcr-trixie"
	},

	// Same Features as the root devcontainer.json, baked into the image at build time.
	"features": {
		// https://github.com/devcontainers/features/blob/main/src/common-utils/
		"ghcr.io/devcontainers/features/common-utils:2": {
			"username": "vscode",
			// already done in container
			"upgradePackages": false,
		},

		// https://github.com/devcontainers/features/tree/main/src/sshd
		// SSHD_PORT/START_SSHD default to 2222/false in the Feature itself, which is
		// what we want - see root ../devcontainer.json's 'forwardPorts' comment.
		"ghcr.io/devcontainers/features/sshd:1": {},

		// https://github.com/devcontainers/features/blob/main/src/node/
		// nodeGypDependencies/pnpmVersion explicitly disabled: their defaults (true /
		// "latest") pull in a full C/C++ build toolchain and pnpm, neither of which
		// anything here uses (only npm, for the npm-packages Feature) - this was the
		// single largest layer in the image (~509MB of ~1.44GB total), dominating
		// build/push time.
		"ghcr.io/devcontainers/features/node:2": {
			"version": "24",
			"nodeGypDependencies": false,
			"pnpmVersion": "none"
		},

		// https://github.com/devcontainers/features/blob/main/src/python/
		"ghcr.io/devcontainers/features/python:1": {
			"version": "os-provided"
		},

		// https://github.com/devcontainers/features/blob/main/src/github-cli/
		"ghcr.io/devcontainers/features/github-cli:1": {},

		// https://github.com/devcontainers/features/blob/main/src/copilot-cli/
		"ghcr.io/devcontainers/features/copilot-cli:1": {},

		// Local Feature (./features/npm-packages) - installsAfter node, since it
		// needs npm. Same packages previously installed via postCreateCommand.
		"./features/npm-packages": {},

		// Published from https://github.com/bugrasan/devcontainers-features -
		// self-contained native binary installer, no npm/node dependency.
		"ghcr.io/bugrasan/devcontainers-features/claude-code:1": {},

		// Published from https://github.com/bugrasan/devcontainers-features -
		// installsAfter node, since it hard-requires Node.js >=22.19.0 + npm.
		"ghcr.io/bugrasan/devcontainers-features/pi-dev:1": {},

		// Published from https://github.com/bugrasan/devcontainers-features - installs
		// the 'specify' CLI (Spec-Driven Development) via uv. Requires Python 3.11+
		// (the python Feature above) and uv (baked into Dockerfile.mcr-trixie), both
		// already present, so it neither installs nor depends on them (installsAfter
		// python only, for cache ordering).
		"ghcr.io/bugrasan/devcontainers-features/speckit:1": {}
	}
}
